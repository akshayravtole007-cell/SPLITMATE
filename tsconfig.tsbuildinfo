@tailwind base;
@tailwind components;
@tailwind utilities;

:root {
  --font-body: 'Sora', system-ui, sans-serif;
  --font-display: 'Sora', system-ui, sans-serif;
  --font-mono: 'DM Mono', monospace;
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: var(--font-body);
  background: #020817;
  background-image:
    radial-gradient(ellipse 80% 50% at 50% -20%, rgba(20, 184, 166, 0.08), transparent),
    radial-gradient(ellipse 60% 40% at 80% 80%, rgba(99, 102, 241, 0.04), transparent);
  min-height: 100vh;
}

/* Scrollbar */
::-webkit-scrollbar { width: 6px; height: 6px; }
::-webkit-scrollbar-track { background: #0f172a; }
::-webkit-scrollbar-thumb { background: #334155; border-radius: 3px; }
::-webkit-scrollbar-thumb:hover { background: #475569; }

/* Input focus ring */
input:focus, textarea:focus, select:focus {
  outline: none;
}

/* Number input arrows hidden */
input[type="number"]::-webkit-inner-spin-button,
input[type="number"]::-webkit-outer-spin-button {
  -webkit-appearance: none;
  margin: 0;
}

@layer components {
  .card {
    @apply bg-slate-900/60 border border-slate-800/60 rounded-2xl backdrop-blur-sm;
  }

  .card-hover {
    @apply card transition-all duration-200 hover:border-slate-700/80 hover:bg-slate-900/80 hover:shadow-lg hover:shadow-black/20;
  }

  .btn-primary {
    @apply bg-brand-500 hover:bg-brand-400 text-white font-semibold px-5 py-2.5 rounded-xl
           transition-all duration-200 active:scale-95 disabled:opacity-50 disabled:cursor-not-allowed
           disabled:active:scale-100 shadow-lg shadow-brand-500/20;
  }

  .btn-secondary {
    @apply bg-slate-800 hover:bg-slate-700 text-slate-200 font-medium px-5 py-2.5 rounded-xl
           transition-all duration-200 active:scale-95 border border-slate-700/60;
  }

  .btn-ghost {
    @apply hover:bg-slate-800/60 text-slate-400 hover:text-slate-200 font-medium px-4 py-2 rounded-xl
           transition-all duration-200 active:scale-95;
  }

  .btn-danger {
    @apply bg-rose-500/10 hover:bg-rose-500/20 text-rose-400 border border-rose-500/20
           font-medium px-4 py-2 rounded-xl transition-all duration-200 active:scale-95;
  }

  .input-field {
    @apply w-full bg-slate-800/60 border border-slate-700/60 rounded-xl px-4 py-3
           text-slate-100 placeholder-slate-500 text-sm
           focus:border-brand-500/60 focus:ring-2 focus:ring-brand-500/20
           transition-all duration-200;
  }

  .label {
    @apply block text-sm font-medium text-slate-400 mb-1.5;
  }

  .badge-green {
    @apply inline-flex items-center gap-1 bg-emerald-500/10 text-emerald-400 border border-emerald-500/20
           text-xs font-semibold px-2.5 py-1 rounded-full;
  }

  .badge-red {
    @apply inline-flex items-center gap-1 bg-rose-500/10 text-rose-400 border border-rose-500/20
           text-xs font-semibold px-2.5 py-1 rounded-full;
  }

  .badge-yellow {
    @apply inline-flex items-center gap-1 bg-amber-500/10 text-amber-400 border border-amber-500/20
           text-xs font-semibold px-2.5 py-1 rounded-full;
  }

  .section-title {
    @apply text-lg font-semibold text-slate-100;
  }

  .text-muted {
    @apply text-slate-500 text-sm;
  }
}
